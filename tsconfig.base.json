// tsconfig.base.json
{
  "compileOnSave": false,
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "importHelpers": true,
    "esModuleInterop": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2017",
      "dom",
      "esnext.asynciterable"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      // --- Існуючі шляхи ---
      "@ridy/admin-panel/*": [
        "apps/admin-panel/*"
      ],
      "@ridy/coupon": [
        "libs/database/src/lib/coupon/index.ts" // Перевірте чи існує цей index.ts
      ],
      "@ridy/database": [
        "libs/database/src/index.ts" // Основний шлях до бібліотеки бази даних
      ],
      // --- Оновлений шлях для database/* (вказує на всю lib) ---
      "@ridy/database/*": [
        "libs/database/src/lib/*"
      ],
      // --- НОВИЙ шлях для common ---
      "@ridy/common": [
        "libs/common/src/index.ts"
      ],
      "@ridy/common/*": [
        "libs/common/src/*" // Або libs/common/src/lib/*, якщо є папка lib
      ],
      // --- Кінець НОВОГО шляху для common ---
      "@ridy/geo/*": [
        "libs/database/src/lib/geo/*"
      ],
      // --- Оновлений шлях для order (припускаючи стандартну структуру) ---
      "@ridy/order": [
        "libs/order/src/index.ts" // Ймовірний правильний шлях
      ],
      "@ridy/order/*": [
        "libs/order/src/lib/*" // Ймовірний правильний шлях
      ],
      // --- Кінець Оновленого шляху для order ---
      "@ridy/payment": [
        "libs/database/src/lib/payment/index.ts" // Перевірте чи існує цей index.ts
      ],
      "@ridy/redis/*": [
        "libs/database/src/lib/redis/*"
      ],
      "@ridy/sms/*": [
        "libs/database/src/lib/sms/*"
      ]
      // --- Додайте сюди шляхи для інших ваших бібліотек, якщо вони є ---
      // Наприклад:
      // "@ridy/config": ["libs/config/src/index.ts"],
      // "@ridy/config/*": ["libs/config/src/lib/*"],
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}